{
    "name": "ts-hh-template",
    "version": "1.0.0",
    "description": "Typescript Hardhat template for CPUchain projects",
    "license": "MIT",
    "author": "CPUchain",
    "scripts": {
        "lint": "eslint scripts/**/*.ts test/**/*.ts --ignore-pattern src/typechain",
        "compile": "hardhat clean && hardhat compile && hardhat flatten:all",
        "deploy": "hardhat run ./scripts/deploy.ts",
        "prettier": "prettier contracts/**/*.sol",
        "test": "hardhat test",
        "coverage": "hardhat clean && hardhat coverage"
    },
    "devDependencies": {
        "@cpuchain/eslint": "^1.0.5",
        "@nomicfoundation/hardhat-chai-matchers": "^2.0.8",
        "@nomicfoundation/hardhat-ethers": "^3.0.8",
        "@nomicfoundation/hardhat-ignition": "^0.15.11",
        "@nomicfoundation/hardhat-ignition-ethers": "^0.15.11",
        "@nomicfoundation/hardhat-network-helpers": "^1.0.12",
        "@nomicfoundation/hardhat-toolbox": "^5.0.0",
        "@nomicfoundation/hardhat-verify": "^2.0.14",
        "@typechain/ethers-v6": "^0.5.1",
        "@typechain/hardhat": "^9.1.0",
        "@types/chai": "^5.2.2",
        "@types/mocha": "^10.0.10",
        "@types/node": "^22.15.21",
        "chai": "^4.2.0",
        "ethers": "^6.14.3",
        "hardhat": "^2.24.1",
        "hardhat-dependency-compiler": "^1.2.1",
        "hardhat-gas-reporter": "^2.2.3",
        "hh-flatten": "^1.0.1",
        "prettier-plugin-solidity": "^2.0.0",
        "solidity-coverage": "^0.8.16",
        "ts-node": "^10.9.2",
        "tsc": "^2.0.4",
        "typechain": "^8.3.2",
        "typescript": "^5.8.3"
    },
    "resolutions": {
        "cookie": "^0.7.2",
        "fast-glob": ">=3.3.3"
    }
}
